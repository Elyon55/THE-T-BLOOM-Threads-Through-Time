<!-- 
  FILE: index.html (First Page - Main Welcome)
  Description: Only the title "THE T-BLOOM" and picture3.png.
  Click anywhere to go to "Different, but Fashion.html"
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>THE T-BLOOM · Welcome</title>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(145deg, #fffaf5 0%, #ffeef4 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: "🌸💗🎀";
      font-size: 280px;
      position: absolute;
      bottom: -60px;
      left: -70px;
      opacity: 0.06;
      pointer-events: none;
      white-space: nowrap;
      z-index: 0;
    }

    body::after {
      content: "✨💕🌸";
      font-size: 240px;
      position: absolute;
      top: -50px;
      right: -60px;
      opacity: 0.05;
      pointer-events: none;
      z-index: 0;
    }

    .hero-card {
      max-width: 1300px;
      width: 100%;
      background: rgba(255, 251, 248, 0.92);
      backdrop-filter: blur(8px);
      border-radius: 64px;
      padding: 3rem 3rem;
      box-shadow: 0 35px 55px -20px rgba(255, 80, 120, 0.3);
      border: 1px solid rgba(255, 210, 225, 0.6);
      z-index: 2;
      transition: transform 0.3s ease;
      cursor: pointer;
    }

    .hero-card:hover {
      transform: scale(1.01);
    }

    .split-layout {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .title-side {
      flex: 1.2;
      text-align: center;
    }

    .main-title {
      font-family: 'Great Vibes', cursive;
      font-size: 5.8rem;
      font-weight: 600;
      background: linear-gradient(125deg, #ff4fa3, #ff8eb5, #ffb3cc);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: 3px;
      line-height: 1.2;
      animation: softGlow 2.5s infinite alternate;
    }

    @keyframes softGlow {
      0% { filter: drop-shadow(0 0 2px rgba(255, 105, 180, 0.2)); }
      100% { filter: drop-shadow(0 0 10px rgba(255, 105, 180, 0.3)); }
    }

    .picture-side {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .hero-image {
      width: 100%;
      max-width: 480px;
      height: auto;
      border-radius: 48px;
      box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.2);
      transition: transform 0.4s ease, box-shadow 0.3s;
      display: block;
      object-fit: cover;
      background: #fce4ec;
    }

    .hero-image:hover {
      transform: scale(1.02);
      box-shadow: 0 30px 45px -12px rgba(255, 80, 120, 0.3);
    }

    .click-hint {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.8rem;
      color: #c47a96;
      opacity: 0.6;
      letter-spacing: 1px;
    }

    @media (max-width: 850px) {
      .split-layout { flex-direction: column; gap: 2rem; }
      .main-title { font-size: 4rem; }
      .hero-image { max-width: 380px; }
      .hero-card { padding: 2rem; }
    }
    @media (max-width: 550px) {
      .main-title { font-size: 2.8rem; }
      .hero-image { max-width: 280px; }
    }
  </style>
</head>
<body>
<div class="hero-card" id="mainGateway">
  <div class="split-layout">
    <div class="title-side">
      <h1 class="main-title">THE T-BLOOM</h1>
    </div>
    <div class="picture-side">
      <img src="images/picture3.png" class="hero-image" alt="bloom visual" onerror="this.src='https://placehold.co/500x500/fce4ec/ff77aa?text=🌸'; this.onerror=null;">
    </div>
  </div>
  <div class="click-hint">✨ click anywhere to enter ✨</div>
</div>
<script>
  // FIXED: Link now points to "Different, but Fashion.html" (with space and capital letters)
  document.getElementById('mainGateway')?.addEventListener('click', () => {
    window.location.href = 'Different, but Fashion.html';
  });
</script>
</body>
</html>
