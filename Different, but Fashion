<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>THE T-BLOOM · Different, but Fashion</title>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      background-image: url('images/picture5.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    /* dark overlay to make text readable and give elegant feel */
    body::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.15) 100%);
      pointer-events: none;
      z-index: 0;
    }

    /* ========== VISIBLE DECORATIONS: floating emojis ========== */
    .floating-emoji {
      position: absolute;
      pointer-events: none;
      z-index: 5;
      font-size: 2rem;
      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));
      animation: floatEmoji 6s infinite ease-in-out;
    }

    @keyframes floatEmoji {
      0%, 100% { transform: translateY(0px) rotate(0deg); opacity: 0.8; }
      50% { transform: translateY(-20px) rotate(8deg); opacity: 1; }
    }

    @keyframes twinkleEmoji {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.15); }
    }

    @keyframes spinEmoji {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .emoji-1 { top: 5%; left: 3%; animation-duration: 5s; }
    .emoji-2 { top: 12%; right: 5%; animation-duration: 7s; animation-delay: 0.5s; }
    .emoji-3 { bottom: 15%; left: 4%; animation-duration: 6s; animation-delay: 1s; }
    .emoji-4 { bottom: 20%; right: 6%; animation-duration: 5.5s; animation-delay: 0.3s; }
    .emoji-5 { top: 30%; left: 2%; animation-duration: 8s; }
    .emoji-6 { top: 55%; right: 3%; animation-duration: 4.5s; }
    .emoji-7 { bottom: 40%; left: 7%; animation-duration: 6.5s; }
    .emoji-8 { top: 70%; right: 8%; animation-duration: 5.8s; }
    .emoji-9 { top: 20%; left: 10%; animation: twinkleEmoji 3s infinite; font-size: 1.5rem; }
    .emoji-10 { bottom: 30%; right: 10%; animation: spinEmoji 10s infinite linear; font-size: 1.6rem; }
    .emoji-11 { top: 45%; left: 88%; animation: floatEmoji 4.5s infinite; font-size: 1.7rem; }
    .emoji-12 { bottom: 10%; left: 15%; animation: twinkleEmoji 3.5s infinite; font-size: 1.5rem; }

    /* main content container */
    .content-container {
      max-width: 800px;
      width: 100%;
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }

    /* ========== TITLE SECTION ========== */
    .title-section {
      text-align: center;
      background: rgba(255, 251, 248, 0.88);
      backdrop-filter: blur(12px);
      border-radius: 70px;
      padding: 2rem 2.5rem;
      box-shadow: 0 30px 45px -20px rgba(0, 0, 0, 0.25), 0 0 0 2px rgba(255, 200, 180, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.5);
      width: 100%;
    }

    .title-main {
      font-family: 'Great Vibes', cursive;
      font-size: 4.5rem;
      background: linear-gradient(125deg, #ff4fa3, #ff8eb5, #e8a87c, #ffb347);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: 2px;
      animation: titlePulse 3s infinite alternate;
    }

    @keyframes titlePulse {
      0%, 100% { filter: drop-shadow(0 0 2px rgba(255, 105, 180, 0.3)); }
      50% { filter: drop-shadow(0 0 18px rgba(255, 160, 120, 0.5)); }
    }

    .title-decoration {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      margin-top: 0.8rem;
      font-size: 1.8rem;
    }

    .title-decoration span {
      animation: floatEmoji 3s infinite;
      display: inline-block;
    }

    .title-decoration span:nth-child(2) { animation-delay: 0.5s; }
    .title-decoration span:nth-child(3) { animation-delay: 1s; }
    .title-decoration span:nth-child(4) { animation-delay: 0.3s; }
    .title-decoration span:nth-child(5) { animation-delay: 0.7s; }

    /* ========== CUTE TEXT BOX ========== */
    .cute-text-box {
      background: rgba(255, 250, 245, 0.92);
      backdrop-filter: blur(16px);
      border-radius: 60px;
      padding: 2rem 2.5rem;
      box-shadow: 0 25px 40px -18px rgba(0, 0, 0, 0.3), 0 0 0 3px rgba(255, 200, 180, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.7);
      text-align: center;
      width: 100%;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .cute-text-box:hover {
      transform: translateY(-5px);
      box-shadow: 0 35px 50px -20px rgba(0, 0, 0, 0.35), 0 0 0 5px rgba(255, 200, 180, 0.5);
    }

    .cute-text {
      font-size: 1.35rem;
      line-height: 1.7;
      color: #4a2e3c;
      font-weight: 500;
    }

    .cute-text .emoji-inline {
      font-size: 1.6rem;
      display: inline-block;
      animation: floatEmoji 2s infinite;
      margin: 0 4px;
    }

    /* decorative elements inside text box */
    .text-box-decoration {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 1.2rem;
      font-size: 1.3rem;
    }

    .text-box-decoration span {
      animation: floatEmoji 3s infinite;
      opacity: 0.8;
    }

    .text-box-decoration span:nth-child(2) { animation-delay: 0.6s; }
    .text-box-decoration span:nth-child(3) { animation-delay: 1.2s; }
    .text-box-decoration span:nth-child(4) { animation-delay: 0.3s; }

    /* ========== NAVIGATION BUTTONS ========== */
    .nav-buttons {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .btn {
      background: linear-gradient(95deg, #ffb347, #ff8c5a);
      padding: 12px 32px;
      border-radius: 60px;
      text-decoration: none;
      color: #3e2a2a;
      font-weight: 700;
      transition: 0.25s;
      box-shadow: 0 6px 14px rgba(255, 140, 70, 0.3);
      font-family: 'Poppins', sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn:hover {
      background: linear-gradient(95deg, #ffc05c, #ffa06a);
      transform: translateY(-3px);
      box-shadow: 0 12px 22px rgba(255, 140, 70, 0.45);
    }

    /* RESPONSIVE */
    @media (max-width: 700px) {
      body { padding: 1rem; }
      .title-main { font-size: 3rem; }
      .cute-text { font-size: 1.05rem; }
      .title-section { padding: 1.5rem; }
      .cute-text-box { padding: 1.5rem; }
      .title-decoration { font-size: 1.2rem; gap: 8px; }
      .btn { padding: 8px 20px; font-size: 0.85rem; }
      .floating-emoji { font-size: 1.3rem; }
    }

    @media (max-width: 480px) {
      .title-main { font-size: 2.2rem; }
      .cute-text { font-size: 0.9rem; }
      .title-decoration span { font-size: 0.9rem; }
    }
  </style>
</head>
<body>

<!-- VISIBLE DECORATIONS: floating emojis all around -->
<div class="floating-emoji emoji-1">🌸</div>
<div class="floating-emoji emoji-2">💗</div>
<div class="floating-emoji emoji-3">🎀</div>
<div class="floating-emoji emoji-4">✨</div>
<div class="floating-emoji emoji-5">💕</div>
<div class="floating-emoji emoji-6">🌟</div>
<div class="floating-emoji emoji-7">🌸</div>
<div class="floating-emoji emoji-8">💖</div>
<div class="floating-emoji emoji-9">⭐</div>
<div class="floating-emoji emoji-10">🎀</div>
<div class="floating-emoji emoji-11">💗</div>
<div class="floating-emoji emoji-12">✨</div>

<div class="content-container">
  <!-- TITLE SECTION -->
  <div class="title-section">
    <h1 class="title-main">Different, but Fashion ✨</h1>
    <div class="title-decoration">
      <span>🌸</span>
      <span>💗</span>
      <span>🎀</span>
      <span>✨</span>
      <span>💕</span>
    </div>
  </div>

  <!-- CUTE TEXT BOX with the message -->
  <div class="cute-text-box">
    <div class="cute-text">
      <span class="emoji-inline">🌸</span> Fashion evolves over time <span class="emoji-inline">🧡</span>, shaped by different voices, cultures, and identities.<br>
      This collection celebrates diverse styles and the ever-changing world of fashion <span class="emoji-inline">💗🎀</span>
    </div>
    <div class="text-box-decoration">
      <span>✨</span>
      <span>🌸</span>
      <span>💗</span>
      <span>🎀</span>
      <span>✨</span>
    </div>
  </div>

  <!-- NAVIGATION BUTTONS -->
  <div class="nav-buttons">
    <a href="index.html" class="btn">◀ Back to Home</a>
    <a href="welcome-bloom.html" class="btn">Next: Welcome Bloom →</a>
  </div>
</div>

</body>
</html>
