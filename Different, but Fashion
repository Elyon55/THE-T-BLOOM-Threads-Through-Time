<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>THE T-BLOOM · Different, but Fashion</title>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #fef6f0;
      font-family: 'Poppins', sans-serif;
      padding: 2rem 2rem 3rem;
    }
    .container { max-width: 1300px; margin: 0 auto; }
    
    /* CHANGED: header-section now uses flex layout to put title and picture opposite each other */
    .header-section {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }
    
    /* left side: title and description text */
    .header-text {
      flex: 1.2;
      text-align: left;
    }
    
    .header-section h1 {
      font-family: 'Great Vibes', cursive;
      font-size: 3.8rem;
      color: #ff4fa3;
      margin-bottom: 0.8rem;
    }
    
    .header-section p {
      font-size: 1.2rem;
      color: #aa6f85;
      max-width: 550px;
      line-height: 1.5;
    }
    
    /* RIGHT SIDE: picture3.png - BIGGER and directly opposite the title */
    .header-image {
      flex: 0.8;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    
    .header-img {
      width: 100%;
      max-width: 380px;
      height: auto;
      border-radius: 32px;
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.15);
      transition: transform 0.3s ease;
      display: block;
      object-fit: cover;
    }
    
    .header-img:hover {
      transform: scale(1.02);
    }
    
    /* RESPONSIVE: on smaller screens, stack vertically */
    @media (max-width: 800px) {
      .header-section {
        flex-direction: column;
        text-align: center;
        gap: 1.5rem;
      }
      .header-text {
        text-align: center;
      }
      .header-section p {
        margin-left: auto;
        margin-right: auto;
      }
      .header-img {
        max-width: 300px;
      }
    }
    
    /* GALLERY - unchanged */
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
      gap: 2rem;
      margin: 2rem 0 3rem;
    }
    .card {
      background: white;
      border-radius: 36px;
      overflow: hidden;
      box-shadow: 0 20px 28px -12px rgba(0,0,0,0.1);
      transition: transform 0.3s, box-shadow 0.2s;
      cursor: pointer;
    }
    .card:hover { transform: translateY(-8px); box-shadow: 0 30px 35px -16px rgba(0,0,0,0.2); }
    .card-img {
      width: 100%;
      aspect-ratio: 1 / 1.2;
      object-fit: cover;
      display: block;
      background: #f3ddd2;
    }
    .card-label { padding: 1rem; text-align: center; font-weight: 600; color: #4c3224; }
    
    /* QUOTE AREA - unchanged */
    .quote-area {
      background: #ffeae0;
      border-radius: 60px;
      padding: 2rem;
      text-align: center;
      margin: 2rem 0;
    }
    .quote-text {
      font-size: 1.5rem;
      font-family: 'Great Vibes', cursive;
      color: #b1556e;
    }
    
    /* NAV BUTTONS - unchanged */
    .nav-buttons {
      display: flex;
      justify-content: center;
      gap: 1.2rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }
    .btn {
      background: #ffbc8c;
      padding: 10px 28px;
      border-radius: 60px;
      text-decoration: none;
      color: #3f2c2c;
      font-weight: 600;
      transition: 0.2s;
    }
    .btn:hover { background: #ffa768; transform: translateY(-3px); }
    
    @media (max-width: 700px) {
      body { padding: 1rem; }
      .header-section h1 { font-size: 2.5rem; }
    }
  </style>
</head>
<body>
<div class="container">
  <!-- CHANGED: header-section now has title + picture opposite each other -->
  <div class="header-section">
    <div class="header-text">
      <h1>✨ Different, but Fashion ✨</h1>
      <p>Fashion evolves over time 🧡, shaped by different voices, cultures, and identities.<br> This collection celebrates diverse styles and the ever-changing world of fashion 🏠</p>
    </div>
    <div class="header-image">
      <img class="header-img" src="images/picture3.png" alt="fashion bloom" onerror="this.src='https://placehold.co/400x400/fbe9e0/ff88aa?text=🌸'">
    </div>
  </div>

  <!-- GALLERY - unchanged (all pictures still here) -->
  <div class="gallery">
    <div class="card"><img class="card-img" src="images/picture2.png" alt="style2" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+2'"><div class="card-label">🌸 Vintage Dream</div></div>
    <div class="card"><img class="card-img" src="images/picture3.png" alt="style3" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+3'"><div class="card-label">🎀 Y2K Edge</div></div>
    <div class="card"><img class="card-img" src="images/picture4.png" alt="style4" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+4'"><div class="card-label">💗 Soft Romance</div></div>
    <div class="card"><img class="card-img" src="images/picture5.png" alt="style5" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+5'"><div class="card-label">✨ Bold Confidence</div></div>
    <div class="card"><img class="card-img" src="images/picture6.png" alt="style6" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+6'"><div class="card-label">🌟 Urban Nostalgia</div></div>
    <div class="card"><img class="card-img" src="images/picture7.png" alt="style7" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+7'"><div class="card-label">🌸 Eternal Glow</div></div>
    <div class="card"><img class="card-img" src="images/picture8.png" alt="style8" onerror="this.src='https://placehold.co/400x500/fbe9e0/ff88aa?text=Style+8'"><div class="card-label">🎀 Modern Muse</div></div>
  </div>

  <!-- QUOTE AREA - unchanged -->
  <div class="quote-area">
    <div class="quote-text">“We all dress differently, but we all express something true about ourselves.”</div>
    <div style="margin-top: 0.6rem;">— Unknown</div>
  </div>

  <!-- NAV BUTTONS - unchanged -->
  <div class="nav-buttons">
    <a href="index.html" class="btn">◀ Back to Home</a>
    <a href="welcome-bloom.html" class="btn">Next: Welcome Bloom →</a>
  </div>
</div>
</body>
</html>
