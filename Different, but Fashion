<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>THE T-BLOOM · Different, but Fashion</title>
  <!-- Google Fonts: Great Vibes for elegance, Poppins for clean style -->
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      overflow-x: hidden;
      /* picture5.png as full page background */
      background-image: url('images/picture5.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;
    }

    /* dark overlay to make text more readable while keeping the image visible */
    body::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.25);
      pointer-events: none;
      z-index: 0;
    }

    /* floating gentle background sparkles (decorative) */
    body::after {
      content: "🌸💗🎀✨";
      font-size: 220px;
      position: absolute;
      bottom: -50px;
      left: -60px;
      opacity: 0.08;
      pointer-events: none;
      white-space: nowrap;
      transform: rotate(-5deg);
      z-index: 0;
    }

    /* main content card — text placed below, elegant and readable */
    .content-card {
      max-width: 750px;
      width: 100%;
      background: rgba(255, 250, 245, 0.92);
      backdrop-filter: blur(12px);
      border-radius: 64px;
      padding: 2.5rem 2.2rem;
      text-align: center;
      box-shadow: 0 30px 50px -18px rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 220, 230, 0.8);
      position: relative;
      z-index: 2;
      animation: fadeSlideUp 0.7s ease-out;
      transition: transform 0.3s ease, box-shadow 0.3s;
    }

    .content-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 40px 60px -20px rgba(0, 0, 0, 0.35);
    }

    @keyframes fadeSlideUp {
      0% {
        opacity: 0;
        transform: translateY(30px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* title styling */
    .page-title {
      font-family: 'Great Vibes', cursive;
      font-size: 3.5rem;
      font-weight: 600;
      background: linear-gradient(125deg, #ff4fa3, #ff8eb5, #ffb3cc);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 1.2rem;
      letter-spacing: 1px;
    }

    /* descriptive text */
    .description-text {
      font-size: 1.2rem;
      line-height: 1.65;
      color: #3d2a35;
      font-weight: 500;
      margin-bottom: 1.8rem;
    }

    .description-text span {
      display: inline-block;
      margin: 0 2px;
    }

    .highlight-icon {
      font-size: 1.3rem;
      display: inline-block;
      animation: bounceSoft 1.5s infinite;
    }

    @keyframes bounceSoft {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }

    /* decorative divider */
    .divider {
      width: 80px;
      height: 3px;
      background: linear-gradient(90deg, #ffb7c5, #ff7ca3);
      border-radius: 10px;
      margin: 1.2rem auto;
    }

    /* navigation buttons */
    .nav-buttons {
      display: flex;
      justify-content: center;
      gap: 1.2rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .btn-nav {
      display: inline-block;
      background: rgba(255, 200, 180, 0.85);
      backdrop-filter: blur(4px);
      padding: 0.7rem 1.6rem;
      border-radius: 60px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      color: #a3516e;
      transition: all 0.25s ease;
      border: 1px solid #ffcddb;
      font-family: 'Poppins', sans-serif;
    }

    .btn-nav:hover {
      background: #ffb79a;
      color: #3e2a2a;
      transform: translateY(-3px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    /* small editor note */
    .editor-note {
      margin-top: 1.8rem;
      font-size: 0.75rem;
      opacity: 0.7;
      color: #9b6a80;
    }

    /* responsive adjustments */
    @media (max-width: 700px) {
      body {
        padding: 1.5rem;
      }
      .content-card {
        padding: 1.8rem 1.5rem;
      }
      .page-title {
        font-size: 2.5rem;
      }
      .description-text {
        font-size: 1rem;
      }
    }

    @media (max-width: 480px) {
      .page-title {
        font-size: 2rem;
      }
      .description-text {
        font-size: 0.9rem;
      }
      .btn-nav {
        padding: 0.5rem 1.2rem;
        font-size: 0.8rem;
      }
    }

    /* sparkle effect on click */
    .sparkle-pop {
      position: fixed;
      pointer-events: none;
      font-size: 1.2rem;
      animation: floatFade 0.7s forwards;
      z-index: 9999;
    }

    @keyframes floatFade {
      0% {
        opacity: 1;
        transform: scale(0.4) translateY(0);
      }
      100% {
        opacity: 0;
        transform: scale(1.1) translateY(-30px);
      }
    }
  </style>
</head>
<body>

<div class="content-card">
  <!-- title: Different, but Fashion -->
  <h1 class="page-title">✨ Different, but Fashion ✨</h1>

  <!-- descriptive text as requested -->
  <div class="description-text">
    Fashion evolves over time <span class="highlight-icon">🌸</span>, shaped by different voices, cultures, and identities.<br>
    This collection celebrates diverse styles and the ever-changing world of fashion <span class="highlight-icon">💗🎀</span>
  </div>

  <div class="divider"></div>

  <!-- subtle extra line for elegance -->
  <p style="font-size: 0.9rem; color: #b66985; font-style: italic;">every style tells a story · every look blooms</p>

  <!-- navigation to other pages -->
  <div class="nav-buttons">
    <a href="index.html" class="btn-nav">🌸 home</a>
    <a href="welcome-bloom.html" class="btn-nav">💕 welcome bloom</a>
    <a href="two-worlds.html" class="btn-nav">🎀 two worlds</a>
    <a href="closing-page.html" class="btn-nav">🌷 final bloom</a>
  </div>

  <div class="editor-note">
    — Editor-in-Chief, Tianah Gaila
  </div>
</div>

<script>
  (function() {
    // sparkle effect on click anywhere for playful interaction
    const card = document.querySelector('.content-card');
    
    function createSparkle(e) {
      const sparkle = document.createElement('div');
      const icons = ['🌸', '💗', '🎀', '✨', '⭐', '💕', '🌷'];
      const randomIcon = icons[Math.floor(Math.random() * icons.length)];
      sparkle.innerHTML = randomIcon;
      sparkle.classList.add('sparkle-pop');
      const x = e.clientX;
      const y = e.clientY;
      sparkle.style.left = (x - 10) + 'px';
      sparkle.style.top = (y - 10) + 'px';
      document.body.appendChild(sparkle);
      setTimeout(() => sparkle.remove(), 700);
    }

    if (card) {
      card.addEventListener('click', (e) => {
        // avoid triggering when clicking on navigation buttons
        if (!e.target.closest('.btn-nav')) {
          createSparkle(e);
        }
      });
    }

    // also add a small floating message when hovering over the title (just for charm)
    const title = document.querySelector('.page-title');
    if (title) {
      title.addEventListener('mouseenter', () => {
        const heartMsg = document.createElement('div');
        heartMsg.innerHTML = '✨ style without limits ✨';
        heartMsg.style.position = 'fixed';
        heartMsg.style.bottom = '20px';
        heartMsg.style.left = '50%';
        heartMsg.style.transform = 'translateX(-50%)';
        heartMsg.style.backgroundColor = '#fff0f5';
        heartMsg.style.color = '#cc6f8c';
        heartMsg.style.padding = '5px 18px';
        heartMsg.style.borderRadius = '40px';
        heartMsg.style.fontSize = '0.7rem';
        heartMsg.style.fontWeight = '500';
        heartMsg.style.zIndex = '1000';
        heartMsg.style.backdropFilter = 'blur(4px)';
        heartMsg.style.border = '1px solid #ffbfcf';
        heartMsg.style.pointerEvents = 'none';
        document.body.appendChild(heartMsg);
        setTimeout(() => {
          heartMsg.style.opacity = '0';
          heartMsg.style.transition = 'opacity 0.3s';
          setTimeout(() => heartMsg.remove(), 500);
        }, 1200);
      });
    }
  })();
</script>
</body>
</html>
